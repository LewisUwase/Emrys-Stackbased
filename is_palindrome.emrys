# is_palindrome.emrys
# Checks whether a string is a palindrome.
#
# CUSTOMORDER  — read the string once
# COPYSTRING   — make a second copy (one job: copy)
# FLIPORDER    — reverse the top copy (one job: reverse)
# SAMETHING    — compare both copies (one job: compare)

ANNOUNCE "Enter a string: "
CUSTOMORDER
COPYSTRING
FLIPORDER
SAMETHING

IFEMPTY NOTPALINDROME
ANNOUNCE "palindrome"
LINEBREAK
CLOSING

NOTPALINDROME:
ANNOUNCE "not a palindrome"
LINEBREAK
CLOSING
